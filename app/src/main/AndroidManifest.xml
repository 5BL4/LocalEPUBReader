<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      FOREGROUND_SERVICE_MEDIA_PLAYBACK declared now (NEVER #10).
      The foregroundServiceType="mediaPlayback" service element and the
      Notification Channel registration arrive in Phase 6 (TTS). The
      permission alone satisfies the never-rule and causes no issues.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".EpubReaderApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.EpubReader">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.EpubReader">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Phase 6: TTS Media3 service (NEVER #10, #16, #25) -->
        <service
            android:name=".media.TtsPlaybackService"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
            </intent-filter>
        </service>

    </application>

</manifest>
