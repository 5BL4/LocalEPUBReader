<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      Readium EpubNavigatorFragment uses a WebView that loads resources via
      https://readium_package/ and https://readium_assets/ URL schemes. Even
      though shouldInterceptRequest() intercepts these requests locally (no
      actual network I/O), the WebView still requires INTERNET permission to
      process https:// URLs. Without this permission, the app crashes when the
      reader opens a book. Both Readium test-app and demos declare INTERNET.
    -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- FOREGROUND_SERVICE_MEDIA_PLAYBACK (NEVER #10). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Android 11+ (API 30+) package visibility: TextToSpeech engine discovery
         requires this <queries> declaration, otherwise TTS init fails silently. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.TTS_SERVICE" />
        </intent>
    </queries>

    <application
        android:name=".EpubReaderApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.EpubReader">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.EpubReader">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Phase 6: TTS Media3 service (NEVER #10, #16, #25) -->
        <service
            android:name=".media.TtsPlaybackService"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
            </intent-filter>
        </service>

        <!-- FileProvider for sharing EPUB files via Intent.ACTION_SEND -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
